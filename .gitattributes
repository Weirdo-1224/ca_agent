# 默认所有文本文件使用 LF
* text=auto eol=lf

# Windows 批处理文件保持 CRLF（Windows 执行需要）
*.cmd text eol=crlf
*.bat text eol=crlf

# 二进制文件不处理换行
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.war binary
*.ear binary
*.zip binary
*.tar binary
*.gz binary
*.pdf binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
